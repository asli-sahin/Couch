{
  "name": "synclify",
  "version": "0.3.1",
  "description": "Create a watch party straight from your browser — works anywhere, ad-free.",
  "author": "andrea",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "deploy": "wxt build && pnpm sentry:sourcemaps",
    "deploy:firefox": "wxt build --browser firefox",
    "postinstall": "wxt prepare",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org synclify --project synclify-extension .output/chrome-mv3 && sentry-cli sourcemaps upload --org synclify --project synclify-extension .output/chrome-mv3"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@sentry/browser": "^8.28.0",
    "@sentry/cli": "^2.35.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "next-themes": "^0.3.0",
    "preact": "^10.23.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "socket.io-client": "^4.7.5",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "webextension-polyfill": "^0.11.0",
    "wxt": "^0.20.18"
  }
}
